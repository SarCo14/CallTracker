<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/card_item"
    android:padding="12dp"
    android:paddingStart="0dp"
    android:layout_marginBottom="8dp"
    android:gravity="center_vertical">
    <View
        android:id="@+id/v_indicator"
        android:layout_width="4dp"
        android:layout_height="40dp"
        android:background="@color/blue"
        android:layout_marginEnd="12dp"/>
    <TextView
        android:id="@+id/tv_call_icon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:text="↙"
        android:textSize="16sp"
        android:gravity="center"
        android:background="@drawable/circle_blue_light"
        android:layout_marginEnd="12dp"/>
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView
            android:id="@+id/tv_call_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:ellipsize="end"/>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp">
            <TextView
                android:id="@+id/tv_call_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"/>
            <TextView
                android:id="@+id/tv_call_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
    </LinearLayout>
    <TextView
        android:id="@+id/tv_call_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textStyle="bold"
        android:padding="5dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/badge_in"
        android:textColor="@color/blue"/>
</LinearLayout>
